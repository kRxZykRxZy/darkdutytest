[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/home.gd" id="1"]
[ext_resource type="FontFile" path="res://fonts/lilita_one_regular.ttf" id="2"]

[sub_resource type="LabelSettings" id="1"]
font = ExtResource("2")
font_size = 48
outline_size = 8

[node name="Home" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.07, 0.09, 0.14, 1)

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Content" type="VBoxContainer" parent="Center"]
layout_mode = 2
theme_override_constants/separation = 14

[node name="Title" type="Label" parent="Center/Content"]
layout_mode = 2
text = "FPS Home"
label_settings = SubResource("1")
horizontal_alignment = 1

[node name="MenuStack" type="VBoxContainer" parent="Center/Content"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/separation = 8

[node name="PlayCampaign" type="Button" parent="Center/Content/MenuStack"]
layout_mode = 2
text = "Play Campaign"

[node name="PlayMultiplayer" type="Button" parent="Center/Content/MenuStack"]
layout_mode = 2
text = "Local Multiplayer"

[node name="CampaignPanel" type="VBoxContainer" parent="Center/Content"]
visible = false
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/separation = 8

[node name="CampaignTitle" type="Label" parent="Center/Content/CampaignPanel"]
layout_mode = 2
text = "Campaign"
horizontal_alignment = 1

[node name="StartCampaign" type="Button" parent="Center/Content/CampaignPanel"]
layout_mode = 2
text = "Start Campaign (Level 1)"

[node name="LevelTwo" type="Button" parent="Center/Content/CampaignPanel"]
layout_mode = 2
text = "Play Level 2"

[node name="LevelThree" type="Button" parent="Center/Content/CampaignPanel"]
layout_mode = 2
text = "Play Level 3"

[node name="CampaignBack" type="Button" parent="Center/Content/CampaignPanel"]
layout_mode = 2
text = "Back"

[node name="MultiplayerPanel" type="VBoxContainer" parent="Center/Content"]
visible = false
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/separation = 6

[node name="MultiplayerTitle" type="Label" parent="Center/Content/MultiplayerPanel"]
layout_mode = 2
text = "Local / LAN Multiplayer"
horizontal_alignment = 1

[node name="HostSettings" type="Label" parent="Center/Content/MultiplayerPanel"]
layout_mode = 2
text = "Host Lobby Settings"

[node name="HostPort" type="SpinBox" parent="Center/Content/MultiplayerPanel"]
unique_name_in_owner = true
layout_mode = 2
min_value = 1024.0
max_value = 65535.0
value = 8910.0

[node name="HostMaxPlayers" type="SpinBox" parent="Center/Content/MultiplayerPanel"]
unique_name_in_owner = true
layout_mode = 2
min_value = 2.0
max_value = 32.0
value = 8.0

[node name="HostPassword" type="LineEdit" parent="Center/Content/MultiplayerPanel"]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "Optional password"

[node name="HostLobby" type="Button" parent="Center/Content/MultiplayerPanel"]
layout_mode = 2
text = "Host Lobby"

[node name="JoinSettings" type="Label" parent="Center/Content/MultiplayerPanel"]
layout_mode = 2
text = "Connect to Lobby"

[node name="JoinAddress" type="LineEdit" parent="Center/Content/MultiplayerPanel"]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "Host URL/IP (example: 192.168.1.20)"

[node name="JoinPort" type="SpinBox" parent="Center/Content/MultiplayerPanel"]
unique_name_in_owner = true
layout_mode = 2
min_value = 1024.0
max_value = 65535.0
value = 8910.0

[node name="JoinPassword" type="LineEdit" parent="Center/Content/MultiplayerPanel"]
unique_name_in_owner = true
layout_mode = 2
placeholder_text = "Lobby password"

[node name="JoinLobby" type="Button" parent="Center/Content/MultiplayerPanel"]
layout_mode = 2
text = "Connect"

[node name="MultiplayerBack" type="Button" parent="Center/Content/MultiplayerPanel"]
layout_mode = 2
text = "Back"

[node name="StatusLabel" type="Label" parent="Center/Content"]
unique_name_in_owner = true
layout_mode = 2
horizontal_alignment = 1

[connection signal="pressed" from="Center/Content/MenuStack/PlayCampaign" to="." method="_on_campaign_pressed"]
[connection signal="pressed" from="Center/Content/MenuStack/PlayMultiplayer" to="." method="_on_local_multiplayer_pressed"]
[connection signal="pressed" from="Center/Content/CampaignPanel/StartCampaign" to="." method="_on_start_campaign_pressed"]
[connection signal="pressed" from="Center/Content/CampaignPanel/LevelTwo" to="." method="_on_level_two_pressed"]
[connection signal="pressed" from="Center/Content/CampaignPanel/LevelThree" to="." method="_on_level_three_pressed"]
[connection signal="pressed" from="Center/Content/CampaignPanel/CampaignBack" to="." method="_on_back_pressed"]
[connection signal="pressed" from="Center/Content/MultiplayerPanel/HostLobby" to="." method="_on_host_lobby_pressed"]
[connection signal="pressed" from="Center/Content/MultiplayerPanel/JoinLobby" to="." method="_on_join_lobby_pressed"]
[connection signal="pressed" from="Center/Content/MultiplayerPanel/MultiplayerBack" to="." method="_on_back_pressed"]
